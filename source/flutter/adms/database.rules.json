{
  "rules": {
    // =========================================================================
    // USERS
    // =========================================================================
    "users": {
      // SECURITY FIX: Only superAdmins can query the full /users collection.
      // Dispatchers & municipalAdmins use child-level rules (scoped by municipality).
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'superAdmin'",

      "$uid": {
        // Users can read their own profile. Admins and super admins can read all.
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' && root.child('users').child(auth.uid).child('municipalityId').val() === data.child('municipalityId').val()) || (root.child('users').child(auth.uid).child('role').val() === 'dispatcher' && root.child('users').child(auth.uid).child('municipalityId').val() === data.child('municipalityId').val()))",
        
        // Users can update their own non-role fields. Admins can update users in their municipality.
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' && root.child('users').child(auth.uid).child('municipalityId').val() === newData.child('municipalityId').val()))",
        
        // Validate user data
        // F3 FIX: Allow partial updates — validate only on create (no existing data)
        ".validate": "(data.exists() && newData.exists()) || newData.hasChildren(['email', 'firstName', 'lastName', 'role', 'createdAt'])",
        
        "role": {
          // Only super admin can change roles
          ".validate": "data.val() === newData.val() || root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin'"
        },
        "isActive": {
          // Only admins can activate/deactivate
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin'"
        },
        "isApproved": {
          // Only admins can approve
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin'"
        }
      }
    },

    // =========================================================================
    // MUNICIPALITIES
    // =========================================================================
    "municipalities": {
      // All authenticated users can read municipalities (for dropdowns, etc.)
      ".read": "auth != null",
      
      "$municipalityId": {
        // Only super admin can create/update municipalities
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' && root.child('users').child(auth.uid).child('municipalityId').val() === $municipalityId))",
        
        // F3 FIX: Allow partial updates — validate only on create (new data), skip validation when existing data is being updated
        ".validate": "(data.exists() && newData.exists()) || newData.hasChildren(['name', 'province', 'region', 'createdAt'])"
      }
    },

    // =========================================================================
    // INCIDENTS
    // =========================================================================
    "incidents": {
      "$municipalityId": {
        // Dispatchers, drivers, and admins in the municipality can read all incidents
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('municipalityId').val() === $municipalityId && (root.child('users').child(auth.uid).child('role').val() === 'dispatcher' || root.child('users').child(auth.uid).child('role').val() === 'driver' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin')))",
        
        "$incidentId": {
          // F5 FIX: Citizens can only CREATE incidents (write if no existing data).
          // Staff roles can update existing incidents.
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('role').val() === 'citizen' && !data.exists()) || (root.child('users').child(auth.uid).child('municipalityId').val() === $municipalityId && (root.child('users').child(auth.uid).child('role').val() === 'dispatcher' || root.child('users').child(auth.uid).child('role').val() === 'driver' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin'))),
          
          // Citizens can also read their own incidents
          ".read": "auth != null && data.child('reporterId').val() === auth.uid",
          
          // F3 FIX: Allow partial updates — validate only on create (no existing data)
          ".validate": "(data.exists() && newData.exists()) || newData.hasChildren(['id', 'municipalityId', 'reporterId', 'latitude', 'longitude', 'severity', 'status', 'createdAt'])"
        }
      }
    },

    // =========================================================================
    // USER INCIDENTS INDEX
    // =========================================================================
    "user_incidents": {
      "$uid": {
        // Users can read their own incident index
        ".read": "auth != null && auth.uid === $uid",
        
        // System creates entries when incidents are reported
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'superAdmin')"
      }
    },

    // =========================================================================
    // INCIDENT INDEX (maps incidentId → municipalityId)
    // =========================================================================
    "incident_index": {
      ".read": "auth != null",
      
      "$incidentId": {
        // SECURITY FIX: Only staff roles can write; prevents citizen tampering
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' || root.child('users').child(auth.uid).child('role').val() === 'dispatcher')"
      }
    },

    // =========================================================================
    // UNITS (Ambulances)
    // =========================================================================
    "units": {
      "$municipalityId": {
        // Dispatchers, drivers, and admins in the municipality can read units
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('municipalityId').val() === $municipalityId)",
        
        "$unitId": {
          // Admins and dispatchers can manage units. Drivers can update their own unit's status/location.
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('municipalityId').val() === $municipalityId && (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' || root.child('users').child(auth.uid).child('role').val() === 'dispatcher' || (root.child('users').child(auth.uid).child('role').val() === 'driver' && data.child('assignedDriverId').val() === auth.uid))))",
          
          // F3 FIX: Allow partial updates — validate only on create (no existing data)
          ".validate": "(data.exists() && newData.exists()) || newData.hasChildren(['id', 'municipalityId', 'callSign', 'type', 'status', 'createdAt'])"
        }
      }
    },

    // =========================================================================
    // DRIVER-UNIT INDEX
    // =========================================================================
    "driver_units": {
      "$driverUid": {
        ".read": "auth != null && (auth.uid === $driverUid || root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' || root.child('users').child(auth.uid).child('role').val() === 'dispatcher')",
        // SECURITY FIX: Added municipality scoping — admins/dispatchers can only
        // assign drivers within their own municipality
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('role').val() in ['municipalAdmin', 'dispatcher'] && root.child('users').child(auth.uid).child('municipalityId').val() === newData.child('municipalityId').val()))"
      }
    },

    // =========================================================================
    // MAINTENANCE
    // =========================================================================
    "maintenance": {
      "$municipalityId": {
        // Dispatchers, admins in the municipality can read maintenance records
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('municipalityId').val() === $municipalityId && (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' || root.child('users').child(auth.uid).child('role').val() === 'dispatcher'))),

        "$maintenanceId": {
          // Municipal admins and dispatchers can create/update maintenance records
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('municipalityId').val() === $municipalityId && (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' || root.child('users').child(auth.uid).child('role').val() === 'dispatcher')))"
        }
      }
    },

    // =========================================================================
    // PATIENT REPORTS (ePCR)
    // =========================================================================
    "patient_reports": {
      "$municipalityId": {
        // Drivers, dispatchers, hospital staff, and admins can read reports
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('municipalityId').val() === $municipalityId && (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' || root.child('users').child(auth.uid).child('role').val() === 'dispatcher' || root.child('users').child(auth.uid).child('role').val() === 'driver'))),

        "$reportId": {
          // Drivers submit reports; dispatchers and admins can update them
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('municipalityId').val() === $municipalityId && (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' || root.child('users').child(auth.uid).child('role').val() === 'dispatcher' || root.child('users').child(auth.uid).child('role').val() === 'driver')))"
        }
      }
    },

    // =========================================================================
    // AUDIT LOG
    // =========================================================================
    "auditLog": {
      // Super admins and municipal admins can read audit entries
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin')",

      "$entryId": {
        // SECURITY FIX: Only Cloud Functions (admin SDK) can write audit entries
        ".write": "false",
        // F3 FIX: Allow partial updates — validate only on create (no existing data)
        ".validate": "(data.exists() && newData.exists()) || newData.hasChildren(['type', 'uid', 'timestamp'])"
      }
    },

    // =========================================================================
    // SYSTEM CONFIG
    // =========================================================================
    "systemConfig": {
      // All authenticated users can read config
      ".read": "auth != null",

      // Only super admin can write system config
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'superAdmin'"
    },

    // =========================================================================
    // INVITES
    // =========================================================================
    "invites": {
      "$token": {
        // Admins can read invites
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin')",

        // Admins can create invites; the invite can be marked used by any auth user (during registration)
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' || (data.exists() && newData.child('used').val() === true))"
      }
    },

    // =========================================================================
    // DRIVER LOCATIONS
    // =========================================================================
    "driver_locations": {
      "$municipalityId": {
        // Dispatchers and admins can read driver locations
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('municipalityId').val() === $municipalityId && (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' || root.child('users').child(auth.uid).child('role').val() === 'dispatcher'))),

        "$unitId": {
          // Only the assigned driver can write their location
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('units').child($municipalityId).child($unitId).child('assignedDriverId').val() === auth.uid))"
        }
      }
    }
  }
}