# =============================================================================
# ADMS - Ambulance Dispatch Management System
# Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in the values.
# The .env file is loaded by flutter_dotenv at startup.
#
# NOTE: Do NOT commit the actual .env file to version control.
#       .env is excluded via .gitignore and the pubspec.yaml assets list.
# =============================================================================

# Firebase Configuration
# For web: get these from Firebase Console → Project Settings → General → Your apps → Web app
# For mobile: get these from Firebase Console → Project Settings → General → Your apps → Android/iOS
FIREBASE_API_KEY=your_api_key_here
FIREBASE_APP_ID=your_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Map SDK (Optional — falls back to OpenStreetMap tiles if not set)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here
# OR (alternative key name for legacy support):
# MAPS_API_KEY=your_maps_api_key_here

# API Base URL (for future server-side features)
# API_BASE_URL=https://api.adms.app/v1