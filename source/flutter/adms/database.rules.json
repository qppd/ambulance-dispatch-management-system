1|1|{
2|2|  "rules": {
3|3|    // =========================================================================
4|4|    // USERS
5|5|    // =========================================================================
6|6|    "users": {
7|7|      // SECURITY FIX: Only superAdmins can query the full /users collection.
8|8|      // Municipal admins use child-level rules (scoped by municipality).
9|9|      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'superAdmin'",
10|10|
11|11|      "$uid": {
12|12|        // Users can read their own profile. Admins and super admins can read all.
13|13|        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' && root.child('users').child(auth.uid).child('municipalityId').val() === data.child('municipalityId').val()) || (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' && root.child('users').child(auth.uid).child('municipalityId').val() === data.child('municipalityId').val()))",
14|14|        
15|15|        // Users can update their own non-role fields. Admins can update users in their municipality.
16|16|        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || (root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin' && root.child('users').child(auth.uid).child('municipalityId').val() === newData.child('municipalityId').val()))",
17|17|        
18|18|        // Validate user data
19|19|        // F3 FIX: Allow partial updates — validate only on create (no existing data)
20|20|        ".validate": "(data.exists() && newData.exists()) || newData.hasChildren(['email', 'firstName', 'lastName', 'role', 'createdAt'])",
21|21|        
22|22|        "role": {
23|23|          // Only super admin can change roles
24|24|          ".validate": "data.val() === newData.val() || root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin'"
25|25|        },
26|26|        "isActive": {
27|27|          // Only admins can activate/deactivate
28|28|          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin'"
29|29|        },
30|30|        "isApproved": {
31|31|          // Only admins can approve
32|32|          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'municipalAdmin'"
33|33|        }
34|34|      }
35|35|    },
